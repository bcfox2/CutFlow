# CutFlow 환경변수 (이 파일을 .env로 복사 후 값 입력)

# 이미지 엔진 선택 (grok|gemini|imagen, 기본: grok)
# IMAGE_ENGINE=grok

# xAI Grok 이미지 생성 API 키 (--engine grok)
XAI_API_KEY=your_xai_api_key_here

# Google API 키 (--engine gemini 또는 --engine imagen)
# https://aistudio.google.com 에서 발급
GOOGLE_API_KEY=your_google_api_key_here

# ElevenLabs TTS API 키
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# ElevenLabs Voice ID (https://elevenlabs.io/app/voice-library 에서 확인)
ELEVENLABS_VOICE_ID=your_voice_id_here
