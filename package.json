{
  "name": "cutflow",
  "version": "0.3.0",
  "description": "대본만 넣으면 CapCut 프로젝트 파일로 완성하는 CLI 도구",
  "type": "module",
  "bin": {
    "cutflow": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:e2e": "vitest run tests/e2e/",
    "test:e2e:real": "dotenv -e .env -- vitest run tests/e2e/real-api.e2e.test.ts",
    "test:watch": "vitest",
    "start": "node dist/cli/index.js"
  },
  "keywords": [
    "capcut",
    "video",
    "automation",
    "tts",
    "cli"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "@google/genai": "^1.47.0",
    "commander": "^14.0.3",
    "dotenv": "^17.3.1",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "vitest": "^4.1.1"
  }
}
